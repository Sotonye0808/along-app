# Core
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_APP_VERSION=0.0.0
PROJECT_ENV=development

# Database (Prisma)
LOCAL_DB=postgresql://USER:PASSWORD@HOST:5432/along
DIRECT_URL=
DATABASE_URL=

# Auth (JWT)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPTILER_STYLE_URL=

# PWA / Push Notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:along@example.com

# Service Worker (dev)
NEXT_PUBLIC_ENABLE_SW_IN_DEV=false

# QStash workers
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Internal notifications
INTERNAL_API_SECRET=

# Platform suggestions
PLATFORM_USER_EMAIL=platform@along.app

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
